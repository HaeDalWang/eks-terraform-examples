---
interface Props {
  title: string;
  breadcrumb?: { label: string; href?: string }[];
}

const { title, breadcrumb = [] } = Astro.props;

// 카테고리 네비게이션
const navItems = [
  { label: '전체 예제', icon: 'apps', href: '/' },
  { label: 'Observability', icon: 'monitoring', href: '/?cat=Observability' },
  { label: 'Service Mesh', icon: 'lan', href: '/?cat=Service+Mesh' },
  { label: 'Gateway', icon: 'hub', href: '/?cat=Gateway' },
  { label: 'CNI / Networking', icon: 'settings_ethernet', href: '/?cat=CNI' },
];
---

<!DOCTYPE html>
<html class="dark" lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | CloudBlueprint</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&family=Noto+Sans+KR:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>
<body class="font-body selection:bg-primary/30">

  <!-- Sidebar -->
  <aside class="fixed left-0 top-0 h-full z-40 bg-surface-container-lowest shadow-[4px_0_24px_rgba(6,14,32,0.6)] w-64 text-sm tracking-wide">
    <div class="p-6">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 mb-10 group">
        <div class="w-10 h-10 bg-primary-container rounded flex items-center justify-center transition-transform group-hover:scale-105">
          <span class="material-symbols-outlined text-on-primary-fixed" style="font-variation-settings: 'FILL' 1;">architecture</span>
        </div>
        <div>
          <h1 class="text-xl font-black tracking-tighter text-primary">CloudBlueprint</h1>
          <p class="text-[10px] uppercase tracking-widest text-secondary font-mono">EKS 템플릿 쇼케이스</p>
        </div>
      </a>

      <!-- Navigation -->
      <nav class="space-y-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class="flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-slate-100 hover:bg-surface-container-high transition-all duration-200"
          >
            <span class="material-symbols-outlined text-[20px]">{item.icon}</span>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>
    </div>

    <!-- Bottom Links -->
    <div class="absolute bottom-8 left-0 w-full px-6 space-y-1">
      <a href="https://github.com" target="_blank" class="flex items-center gap-3 px-4 py-2 text-slate-400 hover:text-slate-100 transition-colors">
        <span class="material-symbols-outlined">code</span>
        <span>GitHub 저장소</span>
      </a>
    </div>
  </aside>

  <!-- Top Header -->
  <header class="fixed top-0 right-0 left-64 z-30 h-16 flex items-center justify-between px-8 bg-surface-container-lowest/70 backdrop-blur-xl">
    <div class="flex items-center gap-2 text-sm">
      {breadcrumb.map((item, i) => (
        <>
          {i > 0 && <span class="material-symbols-outlined text-[16px] text-slate-600">chevron_right</span>}
          {item.href ? (
            <a href={item.href} class="text-slate-500 hover:text-primary transition-colors">{item.label}</a>
          ) : (
            <span class="text-primary font-medium">{item.label}</span>
          )}
        </>
      ))}
    </div>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 text-[10px] font-mono uppercase tracking-widest text-slate-500">
        <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
        라이브 저장소
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="ml-64 pt-16 min-h-screen">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="ml-64 flex justify-between items-center px-8 py-6 bg-surface-container-lowest border-t border-surface-container-high/50 font-mono text-[10px] uppercase tracking-widest">
    <div class="text-secondary font-bold">
      © 2024 CloudBlueprint EKS 인프라 패턴
    </div>
    <div class="flex items-center gap-6">
      <a class="text-slate-500 hover:text-slate-300 transition-all" href="#">문서</a>
      <a class="text-slate-500 hover:text-slate-300 transition-all" href="#">GitHub 저장소</a>
    </div>
  </footer>

</body>
</html>

<style is:global>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    vertical-align: middle;
  }
</style>
